# Roundtable Legends Environment Configuration
# Copy this file to .env and populate with your actual credentials

# ============================================================================
# UPSTASH REDIS CONFIGURATION (Agent Registry + Session Timeline)
# ============================================================================
# Get these from your Upstash Redis database details page.
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# ============================================================================
# UPSTASH VECTOR CONFIGURATION (Discussion Vectors)
# ============================================================================
# Get these from your Upstash Vector index details page.
UPSTASH_VECTOR_REST_URL=https://your-vector-index.upstash.io
UPSTASH_VECTOR_REST_TOKEN=your_upstash_vector_rest_token_here

# ============================================================================
# HUGGING FACE CONFIGURATION (LLM API)
# ============================================================================
# Generate a token at: https://huggingface.co/settings/tokens
# Requires "Inference API" access
HF_TOKEN=hf_your_token_here
HF_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.1

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================
# FastAPI server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info

# ============================================================================
# FRONTEND CONFIGURATION (Streamlit)
# ============================================================================
# Backend URL that Streamlit frontend connects to
BACKEND_URL=http://localhost:8000

# ============================================================================
# OPTIONAL: MONITORING & LOGGING
# ============================================================================
# Sentry error tracking (optional)
# SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
